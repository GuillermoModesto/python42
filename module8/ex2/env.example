# "development" or "production"
MATRIX_MODE=development

# Database connection string
# Format: dialect://user:password@host:port/database
DATABASE_URL=postgresql://neo:whiterabbit@localhost:5432/matrix_dev

# Secret key used to authenticate against external APIs
API_KEY=your_api_key_here

# Logging verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG

# URL of the Zion resistance network endpoint
ZION_ENDPOINT=http://localhost:8080/zion
